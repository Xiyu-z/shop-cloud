<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shop.order.mapper.SysOrderMapper">

    <resultMap id="BaseResultMap" type="com.shop.core.domain.entity.SysOrder">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="pid" column="pid" jdbcType="INTEGER"/>
            <result property="name" column="name" jdbcType="VARCHAR"/>
            <result property="price" column="price" jdbcType="VARCHAR"/>
            <result property="sum" column="sum" jdbcType="VARCHAR"/>
            <result property="img" column="img" jdbcType="VARCHAR"/>
            <result property="imgs" column="imgs" jdbcType="VARCHAR"/>
            <result property="details" column="details" jdbcType="VARCHAR"/>
            <result property="num" column="num" jdbcType="INTEGER"/>
            <result property="attr" column="attr" jdbcType="VARCHAR"/>
            <result property="numbers" column="numbers" jdbcType="VARCHAR"/>
            <result property="status" column="status" jdbcType="VARCHAR"/>
            <result property="type" column="type" jdbcType="VARCHAR"/>
            <result property="environment" column="environment" jdbcType="VARCHAR"/>
            <result property="createBy" column="create_by" jdbcType="BIGINT"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateBy" column="update_by" jdbcType="BIGINT"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="remarks" column="remarks" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,pid,name,status,numbers,
        price,sum,img,
        imgs,details,num,
        attr,type,environment,
        create_by,create_time,update_by,
        update_time,remarks
    </sql>
    <select id="productStats" resultType="com.shop.core.domain.vo.EchartsVo">
        SELECT
        '普通商品' AS `name`,
        COUNT(*) AS `value`
        FROM
        sys_order
        WHERE
        create_by = #{userId}
        AND ( type IS NULL OR type = '' ) UNION ALL
        SELECT
        '环保商品' AS `name`,
        COUNT(*) AS `value`
        FROM
        sys_order
        WHERE
        create_by = #{userId}
        AND type IS NOT NULL
        AND type != '';
    </select>
</mapper>
